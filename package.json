{
  "name": "local-player",
  "version": "1.0.7",
  "description": "Local video player with Plyr + hls.js and sprite preview thumbnails",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.localplayer.app",
    "productName": "Local Player",
    "icon": "icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "vendor/**",
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "icon": "icon.ico",
      "artifactName": "LocalPlayer-Setup.exe",
      "target": "nsis"
    },
    "mac": {
      "icon": "icon.icns",
      "artifactName": "LocalPlayer.dmg",
      "target": "dmg"
    },
    "linux": {
      "icon": "icon.png",
      "category": "AudioVideo",
      "artifactName": "LocalPlayer.AppImage",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "hls.js": "^1.6.16",
    "plyr": "^3.8.4",
    "sharp": "^0.34.5"
  }
}

{
  "name": "local-player",
  "version": "1.0.0",
  "description": "Local video player with Plyr + hls.js and sprite preview thumbnails",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.localplayer.app",
    "productName": "Local Player",
    "icon": "icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "win": {
      "icon": "icon.ico",
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
